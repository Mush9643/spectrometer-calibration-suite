		<region region-id="2010" left="24" top="2612.25" width="390.75" height="24" align-x="43.5" align-y="2622" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<text use-page-width="false" push-down="false" lock-width="true">
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Значения в спектре начинаются с 11 канала. Поэтому нижний уровень дискриминации пусть будет 10 канал</p>
			</text>
		</region>
