			<text use-page-width="false" push-down="false" lock-width="true">
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">это меньше чем 0.2 значит прибор проходной</p>
			</text>
		</region>
		<region region-id="2018" left="30" top="2828.25" width="370.5" height="36" align-x="36" align-y="2838" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<text use-page-width="false" push-down="false" lock-width="true">
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">вот такое разделение между альфа и бета. если нет в выбросах родия-рутения то можно сдвигать влево, иначе так и оставляем. чувствительность к урану немного просаживается</p>
			</text>
		</region>
